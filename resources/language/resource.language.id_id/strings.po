msgctxt "#30104"
msgid "[B]CURRENT MODE: Swap[/B]\nSelect a favorite then another.\nThey will swap places."
msgstr "[B]MODE SAAT INI: Tukar[/B]\nPilih satu favorit lalu yang lain.\nMereka akan bertukar tempat."

msgctxt "#30105"
msgid "[B]CURRENT MODE: Insert Before[/B]\nSelect an item and then the destination.\nThe first will move just [B]before[/B] the second."
msgstr "[B]MODE SAAT INI: Masukkan Sebelum[/B]\nPilih item lalu tujuannya.\nYang pertama akan berpindah tepat [B]sebelum[/B] yang kedua."

msgctxt "#30106"
msgid "[B]CURRENT MODE: Insert After[/B]\nSelect an item then the destination.\nThe first will move just [B]after[/B] the second."
msgstr "[B]MODE SAAT INI: Masukkan Sesudah[/B]\nPilih item lalu tujuannya.\nYang pertama akan berpindah tepat [B]sesudah[/B] yang kedua."

msgctxt "#30107"
msgid "[B]CURRENT MODE: Arrow Move[/B]\nSelect a favorite and use UP/DOWN keys to move it.\nPress the SAME favorite to release it."
msgstr "[B]MODE SAAT INI: Pindah Panah[/B]\nPilih favorit dan gunakan tombol ATAS/BAWAH untuk memindahkannya.\nTekan favorit yang SAMA untuk melepaskannya."

msgctxt "#30108"
msgid "\n\n[B]CHANGE MODE:[/B]\nUse the sidebar button to rotate between these behaviors according to your preference."
msgstr "\n\n[B]UBAH MODE:[/B]\nGunakan tombol sidebar untuk beralih di antara perilaku ini sesuai preferensi Anda."

msgctxt "#30109"
msgid "\n\n[B]CONTEXT MENU[/B] (extra options):"
msgstr "\n\n[B]MENU KONTEKS[/B] (opsi tambahan):"

msgctxt "#30110"
msgid "\n- PC: Right Click or 'C' key\n- Remote/TV: 'Menu' button\n- Touch: Long Press"
msgstr "\n- PC: Klik Kanan atau tombol 'C'\n- Remote/TV: Tombol 'Menu'\n- Sentuh: Tekan Lama"

msgctxt "#30111"
msgid "\n\n[B]TIPS:[/B]\n- [I]Multiselect[/I]: select multiple to move in block\n- [I]Carousel[/I]: In arrow mode, reaching the end jumps to the beginning"
