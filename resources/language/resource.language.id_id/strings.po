msgstr "Menginstal otomatis {0} (cadangan)..."

msgctxt "#30506"
msgid "The {0} repository was installed, but the addon installation did not complete.\n\nTo finish manually:\nAddons - Install from repository - {0} - Install"
msgstr "Repositori {0} telah diinstal, tetapi penginstalan addon tidak selesai.\n\nUntuk menyelesaikan secara manual:\nAddons - Instal dari repositori - {0} - Instal"

