msgstr "Penginstal otomatis (disarankan)"

msgctxt "#30513"
msgid "View manual installation instructions"
msgstr "Lihat petunjuk penginstalan manual"

msgctxt "#30514"
msgid "loiolog is not installed.\n\nDownload and install automatically?"
msgstr "loiolog belum diinstal.\n\nUnduh dan instal secara otomatis?"

msgctxt "#30515"
msgid "loiolog instructions"
msgstr "instruksi loiolog"

msgctxt "#30516"
msgid "[B]How to install loiolog[/B]\n\n1. Settings - System - Addons - enable Unknown Sources\n\n2. Settings - File Manager - Add source:\n   {0}\n\n3. Addons - Install from zip file - loiolog\n   repository.loiolog-x.x.x.zip\n\n4. Install from repository - loiolog - Program Addons - loiolog"
msgstr "[B]Cara menginstal loiolog[/B]\n\n1. Pengaturan - Sistem - Addons - aktifkan Sumber Tidak Dikenal\n\n2. Pengaturan - Manajer File - Tambahkan sumber:\n   {0}\n\n3. Addons - Instal dari file zip - loiolog\n   repository.loiolog-x.x.x.zip\n\n4. Instal dari repositori - loiolog - Program Addons - loiolog"

msgctxt "#30517"
msgid "Add advanced editor to Kodi favourites"
msgstr "Tambahkan editor lanjutan ke favorit Kodi"

msgctxt "#30518"
msgid "Advanced editor added. Reload skin or restart Kodi to see it"
msgstr "Editor lanjutan ditambahkan. Muat ulang skin atau mulai ulang Kodi untuk melihatnya"

