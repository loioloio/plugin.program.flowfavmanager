msgctxt "#30104"
msgid "[B]CURRENT MODE: Swap[/B]\nSelect a favorite then another.\nThey will swap places."
msgstr "[B]CHẾ ĐỘ HIỆN TẠI: Hoán đổi[/B]\nChọn một mục yêu thích rồi chọn mục khác.\nChúng sẽ đổi chỗ cho nhau."

msgctxt "#30105"
msgid "[B]CURRENT MODE: Insert Before[/B]\nSelect an item and then the destination.\nThe first will move just [B]before[/B] the second."
msgstr "[B]CHẾ ĐỘ HIỆN TẠI: Chèn vào trước[/B]\nChọn một mục rồi chọn đích đến.\nMục đầu tiên sẽ di chuyển đến ngay [B]trước[/B] mục thứ hai."

msgctxt "#30106"
msgid "[B]CURRENT MODE: Insert After[/B]\nSelect an item then the destination.\nThe first will move just [B]after[/B] the second."
msgstr "[B]CHẾ ĐỘ HIỆN TẠI: Chèn vào sau[/B]\nChọn một mục rồi chọn đích đến.\nMục đầu tiên sẽ di chuyển đến ngay [B]sau[/B] mục thứ hai."

msgctxt "#30107"
msgid "[B]CURRENT MODE: Arrow Move[/B]\nSelect a favorite and use UP/DOWN keys to move it.\nPress the SAME favorite to release it."
msgstr "[B]CHẾ ĐỘ HIỆN TẠI: Di chuyển bằng phím mũi tên[/B]\nChọn một mục yêu thích và sử dụng các phím LÊN/XUỐNG để di chuyển.\nNhấn vào CHÍNH MỤC ĐÓ để thả ra."

msgctxt "#30108"
msgid "\n\n[B]CHANGE MODE:[/B]\nUse the sidebar button to rotate between these behaviors according to your preference."
msgstr "\n\n[B]ĐỔI CHẾ ĐỘ:[/B]\nSử dụng nút thanh bên để xoay vòng giữa các hành vi này theo sở thích của bạn."

msgctxt "#30109"
msgid "\n\n[B]CONTEXT MENU[/B] (extra options):"
msgstr "\n\n[B]MENU NGỮ CẢNH[/B] (tùy chọn bổ sung):"

msgctxt "#30110"
msgid "\n- PC: Right Click or 'C' key\n- Remote/TV: 'Menu' button\n- Touch: Long Press"
