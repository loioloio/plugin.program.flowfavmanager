msgctxt "#30103"
msgid "Help & Instructions"
msgstr "সহায়তা এবং নির্দেশাবলী"

msgctxt "#30104"
msgid "[B]CURRENT MODE: Swap[/B]\nSelect a favorite then another.\nThey will swap places."
msgstr "[B]বর্তমান মোড: অদলবদল[/B]\nএকটি পছন্দ নির্বাচন করুন তারপর অন্য একটি।\nতারা স্থান বিনিময় করবে।"

msgctxt "#30105"
msgid "[B]CURRENT MODE: Insert Before[/B]\nSelect an item and then the destination.\nThe first will move just [B]before[/B] the second."
msgstr "[B]বর্তমান মোড: আগে ঢোকান[/B]\nএকটি আইটেম নির্বাচন করুন এবং তারপর গন্তব্য।\nপ্রথমটি দ্বিতীয়টির ঠিক [B]আগে[/B] চলে যাবে।"

msgctxt "#30106"
msgid "[B]CURRENT MODE: Insert After[/B]\nSelect an item then the destination.\nThe first will move just [B]after[/B] the second."
msgstr "[B]বর্তমান মোড: পরে ঢোকান[/B]\nএকটি আইটেম নির্বাচন করুন তারপর গন্তব্য।\nপ্রথমটি দ্বিতীয়টির ঠিক [B]পরে[/B] চলে যাবে।"

msgctxt "#30107"
msgid "[B]CURRENT MODE: Arrow Move[/B]\nSelect a favorite and use UP/DOWN keys to move it.\nPress the SAME favorite to release it."
msgstr "[B]বর্তমান মোড: তীর চিহ্ন দিয়ে সরান[/B]\nএকটি পছন্দ নির্বাচন করুন এবং এটি সরানোর জন্য উপরে/নিচে কী ব্যবহার করুন।\nছাড়ার জন্য একই পছন্দের আইটেমে চাপ দিন।"

msgctxt "#30108"
msgid "\n\n[B]CHANGE MODE:[/B]\nUse the sidebar button to rotate between these behaviors according to your preference."
msgstr "\n\n[B]মোড পরিবর্তন করুন:[/B]\nআপনার পছন্দ অনুযায়ী এই আচরণগুলির মধ্যে পরিবর্তন করতে সাইডবার বোতামটি ব্যবহার করুন।"

msgctxt "#30109"
msgid "\n\n[B]CONTEXT MENU[/B] (extra options):"
msgstr "\n\n[B]প্রসঙ্গ মেনু[/B] (অতিরিক্ত বিকল্পগুলি):"

msgctxt "#30110"
msgid "\n- PC: Right Click or 'C' key\n- Remote/TV: 'Menu' button\n- Touch: Long Press"
msgstr "\n- পিসি: রাইট ক্লিক অথবা 'C' কী\n- রিমোট/টিভি: 'মেনু' বোতাম\n- টাচ: দীর্ঘক্ষণ চেপে ধরুন"

msgctxt "#30111"
msgid "\n\n[B]TIPS:[/B]\n- [I]Multiselect[/I]: select multiple to move in block\n- [I]Carousel[/I]: In arrow mode, reaching the end jumps to the beginning"
msgstr "\n\n[B]পরামর্শ:[/B]\n- [I]মাল্টি-সিলেক্ট[/I]: একসাথে সরানোর জন্য একাধিক নির্বাচন করুন\n- [I]ক্যারোজেল[/I]: তীর মোডে, শেষে পৌঁছালে শুরুতে চলে যায়"

