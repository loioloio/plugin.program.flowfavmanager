msgctxt "#30104"
msgid "[B]CURRENT MODE: Swap[/B]\nSelect a favorite then another.\nThey will swap places."
msgstr "[B]موجودہ موڈ: تبادلہ[/B]\nایک پسندیدہ منتخب کریں پھر دوسرا۔\nوہ جگہیں بدل لیں گے۔"

msgctxt "#30105"
msgid "[B]CURRENT MODE: Insert Before[/B]\nSelect an item and then the destination.\nThe first will move just [B]before[/B] the second."
msgstr "[B]موجودہ موڈ: پہلے ڈالیں[/B]\nایک آئٹم منتخب کریں اور پھر منزل۔\nپہلا دوسرے کے بالکل [B]پہلے[/B] چلا جائے گا۔"

msgctxt "#30106"
msgid "[B]CURRENT MODE: Insert After[/B]\nSelect an item then the destination.\nThe first will move just [B]after[/B] the second."
msgstr "[B]موجودہ موڈ: بعد میں ڈالیں[/B]\nایک آئٹم منتخب کریں اور پھر منزل۔\nپہلا دوسرے کے بالکل [B]بعد[/B] چلا جائے گا۔"

msgctxt "#30107"
msgid "[B]CURRENT MODE: Arrow Move[/B]\nSelect a favorite and use UP/DOWN keys to move it.\nPress the SAME favorite to release it."
msgstr "[B]موجودہ موڈ: تیر سے حرکت[/B]\nایک پسندیدہ منتخب کریں اور اسے حرکت دینے کے لیے اوپر/نیچے کی چابیاں استعمال کریں۔\nاسے چھوڑنے کے لیے اسی پسندیدہ کو دبائیں۔"

msgctxt "#30108"
msgid "\n\n[B]CHANGE MODE:[/B]\nUse the sidebar button to rotate between these behaviors according to your preference."
msgstr "\n\n[B]موڈ تبدیل کریں:[/B]\nاپنی پسند کے مطابق ان رویوں کے درمیان بدلنے کے لیے سائیڈ بار بٹن کا استعمال کریں۔"

msgctxt "#30109"
