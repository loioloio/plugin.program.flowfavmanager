msgctxt "#30108"
msgid "\n\n[B]CHANGE MODE:[/B]\nUse the sidebar button to rotate between these behaviors according to your preference."
msgstr "\n\n[B]ИЗМЕНИТЬ РЕЖИМ:[/B]\nИспользуйте кнопку на боковой панели для переключения между этими действиями в соответствии с вашими предпочтениями."

