msgstr "loiolog Anleitung"

msgctxt "#30516"
msgid "[B]How to install loiolog[/B]\n\n1. Settings - System - Addons - enable Unknown Sources\n\n2. Settings - File Manager - Add source:\n   {0}\n\n3. Addons - Install from zip file - loiolog\n   repository.loiolog-x.x.x.zip\n\n4. Install from repository - loiolog - Program Addons - loiolog"
msgstr "[B]So installieren Sie loiolog[/B]\n\n1. Einstellungen - System - Addons - Unbekannte Quellen aktivieren\n\n2. Einstellungen - Dateimanager - Quelle hinzufügen:\n   {0}\n\n3. Addons - Aus ZIP-Datei installieren - loiolog\n   repository.loiolog-x.x.x.zip\n\n4. Aus Repository installieren - loiolog - Programm-Addons - loiolog"

msgctxt "#30517"
msgid "Add advanced editor to Kodi favourites"
msgstr "Editor zu Kodi-Favoriten hinzufügen"

msgctxt "#30518"
msgid "Advanced editor added. Reload skin or restart Kodi to see it"
msgstr "Editor hinzugefügt. Skin neu laden oder Kodi neu starten"

msgctxt "#30519"
msgid "Advanced editor already in Kodi favourites"
msgstr "Editor ist bereits in den Kodi-Favoriten vorhanden"

msgctxt "#30520"
