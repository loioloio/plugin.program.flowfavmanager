msgid "Could not install {0} automatically.\n\nError: {1}\n\nYou may need to enable Unknown Sources in Settings."
msgstr "{0} konnte nicht automatisch installiert werden.\n\nFehler: {1}\n\nMöglicherweise müssen Sie Unbekannte Quellen in den Einstellungen aktivieren."


msgctxt "#30510"
