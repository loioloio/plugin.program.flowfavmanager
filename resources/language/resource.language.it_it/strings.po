msgctxt "#30104"
msgid "[B]CURRENT MODE: Swap[/B]\nSelect a favorite then another.\nThey will swap places."
msgstr "[B]MODALITÀ ATTUALE: Scambio[/B]\nSeleziona un preferito, poi un altro.\nSi scambieranno di posto."

msgctxt "#30105"
msgid "[B]CURRENT MODE: Insert Before[/B]\nSelect an item and then the destination.\nThe first will move just [B]before[/B] the second."
msgstr "[B]MODALITÀ ATTUALE: Inserisci prima[/B]\nSeleziona un elemento, poi la destinazione.\nIl primo verrà spostato appena [B]prima[/B] del secondo."

msgctxt "#30106"
msgid "[B]CURRENT MODE: Insert After[/B]\nSelect an item then the destination.\nThe first will move just [B]after[/B] the second."
msgstr "[B]MODALITÀ ATTUALE: Inserisci dopo[/B]\nSeleziona un elemento, poi la destinazione.\nIl primo verrà spostato appena [B]dopo[/B] il secondo."

msgctxt "#30107"
msgid "[B]CURRENT MODE: Arrow Move[/B]\nSelect a favorite and use UP/DOWN keys to move it.\nPress the SAME favorite to release it."
msgstr "[B]MODALITÀ ATTUALE: Sposta con frecce[/B]\nSeleziona un preferito e usa i tasti SU/GIÙ per spostarlo.\nPremi lo STESSO preferito per rilasciarlo."

msgctxt "#30108"
msgid "\n\n[B]CHANGE MODE:[/B]\nUse the sidebar button to rotate between these behaviors according to your preference."
msgstr "\n\n[B]CAMBIA MODALITÀ:[/B]\nUsa il pulsante nella barra laterale per passare da un comportamento all'altro."

msgctxt "#30109"
msgid "\n\n[B]CONTEXT MENU[/B] (extra options):"
msgstr "\n\n[B]MENU CONTESTUALE[/B] (opzioni extra):"

msgctxt "#30110"
msgid "\n- PC: Right Click or 'C' key\n- Remote/TV: 'Menu' button\n- Touch: Long Press"
msgstr "\n- PC: Clic destro o tasto 'C'\n- Telecomando/TV: Pulsante 'Menu'\n- Touch: Pressione prolungata"

msgctxt "#30111"
msgid "\n\n[B]TIPS:[/B]\n- [I]Multiselect[/I]: select multiple to move in block\n- [I]Carousel[/I]: In arrow mode, reaching the end jumps to the beginning"
msgstr "\n\n[B]SUGGERIMENTI:[/B]\n- [I]Multiselezione[/I]: seleziona più elementi per spostarli in blocco\n- [I]Carosello[/I]: In modalità frecce, quando arrivi alla fine torni all'inizio"

