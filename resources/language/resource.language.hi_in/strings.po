msgctxt "#30110"
msgid "\n- PC: Right Click or 'C' key\n- Remote/TV: 'Menu' button\n- Touch: Long Press"
msgstr "\n- पीसी: राइट क्लिक या 'C' की\n- रिमोट/टीवी: 'मेनू' बटन\n- टच: लॉन्ग प्रेस"

msgctxt "#30111"
msgid "\n\n[B]TIPS:[/B]\n- [I]Multiselect[/I]: select multiple to move in block\n- [I]Carousel[/I]: In arrow mode, reaching the end jumps to the beginning"
msgstr "\n\n[B]टिप्स:[/B]\n- [I]बहुचयन[/I]: ब्लॉक में स्थानांतरित करने के लिए कई चुनें\n- [I]हिंडोला[/I]: एरो मोड में, अंत तक पहुँचने पर शुरुआत में कूद जाता है"

