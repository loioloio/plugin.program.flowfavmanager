msgctxt "#30107"
msgid "[B]CURRENT MODE: Arrow Move[/B]\nSelect a favorite and use UP/DOWN keys to move it.\nPress the SAME favorite to release it."
msgstr "[B]वर्तमान मोड: एरो मूव[/B]\nएक पसंदीदा चुनें और उसे स्थानांतरित करने के लिए ऊपर/नीचे कुंजियों का उपयोग करें।\nरिलीज़ करने के लिए उसी पसंदीदा को दबाएं।"

msgctxt "#30108"
msgid "\n\n[B]CHANGE MODE:[/B]\nUse the sidebar button to rotate between these behaviors according to your preference."
msgstr "\n\n[B]मोड बदलें:[/B]\nअपनी पसंद के अनुसार इन व्यवहारों के बीच घूमने के लिए साइडबार बटन का उपयोग करें।"

msgctxt "#30109"
