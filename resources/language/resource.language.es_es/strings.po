msgctxt "#30104"
msgid "[B]CURRENT MODE: Swap[/B]\nSelect a favorite then another.\nThey will swap places."
msgstr "[B]MODO ACTUAL: Intercambiar[/B]\nSelecciona un favorito y luego otro.\nSe intercambiarán de lugar entre sí."

msgctxt "#30105"
msgid "[B]CURRENT MODE: Insert Before[/B]\nSelect an item and then the destination.\nThe first will move just [B]before[/B] the second."
msgstr "[B]MODO ACTUAL: Insertar Antes[/B]\nSelecciona un item y luego el destino.\nEl primero se moverá justo [B]antes[/B] del segundo."

msgctxt "#30106"
msgid "[B]CURRENT MODE: Insert After[/B]\nSelect an item then the destination.\nThe first will move just [B]after[/B] the second."
msgstr "[B]MODO ACTUAL: Insertar Después[/B]\nSelecciona un item y luego el destino.\nEl primero se moverá justo [B]después[/B] del segundo."

msgctxt "#30107"
msgid "[B]CURRENT MODE: Arrow Move[/B]\nSelect a favorite and use UP/DOWN keys to move it.\nPress the SAME favorite to release it."
msgstr "[B]MODO ACTUAL: Mover con Flechas[/B]\nSelecciona un favorito y usa las flechas ARRIBA/ABAJO para moverlo.\nPulsa el MISMO favorito para soltarlo."

msgctxt "#30108"
msgid "\n\n[B]CHANGE MODE:[/B]\nUse the sidebar button to rotate between these behaviors according to your preference."
msgstr "\n\n[B]CAMBIAR MODO:[/B]\nUsa el botón del menú lateral para rotar entre estos comportamientos según tu preferencia."

msgctxt "#30109"
msgid "\n\n[B]CONTEXT MENU[/B] (extra options):"
msgstr "\n\n[B]MENÚ CONTEXTUAL[/B] (opciones extra):"

msgctxt "#30110"
msgid "\n- PC: Right Click or 'C' key\n- Remote/TV: 'Menu' button\n- Touch: Long Press"
msgstr "\n- PC: Clic derecho o tecla 'C'\n- Mando/TV: Botón 'Menú'\n- Táctil: Pulsación Larga"

msgctxt "#30111"
msgid "\n\n[B]TIPS:[/B]\n- [I]Multiselect[/I]: select multiple to move in block\n- [I]Carousel[/I]: In arrow mode, reaching the end jumps to the beginning"
