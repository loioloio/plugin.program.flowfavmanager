msgctxt "#30107"
msgid "[B]CURRENT MODE: Arrow Move[/B]\nSelect a favorite and use UP/DOWN keys to move it.\nPress the SAME favorite to release it."
msgstr "[B]MODO ATUAL: Mover com Setas[/B]\nSelecione um favorito e use as teclas CIMA/BAIXO para movê-lo.\nPressione o MESMO favorito para soltá-lo."

msgctxt "#30108"
msgid "\n\n[B]CHANGE MODE:[/B]\nUse the sidebar button to rotate between these behaviors according to your preference."
msgstr "\n\n[B]ALTERAR MODO:[/B]\nUse o botão lateral para alternar entre estes comportamentos conforme sua preferência."

msgctxt "#30109"
msgid "\n\n[B]CONTEXT MENU[/B] (extra options):"
