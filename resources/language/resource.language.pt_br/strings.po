msgstr "Erro de instalação"

msgctxt "#30508"
msgid "Could not install {0} automatically.\n\nError: {1}\n\nYou may need to enable Unknown Sources in Settings."
msgstr "Não foi possível instalar {0} automaticamente.\n\nErro: {1}\n\nTalvez seja necessário ativar Fontes desconhecidas nas Configurações."

msgctxt "#30510"
msgid "Opening loiolog..."
msgstr "Abrindo loiolog..."

msgctxt "#30511"
msgid "loiolog - installation"
msgstr "loiolog - instalação"

msgctxt "#30512"
msgid "Auto installer (recommended)"
msgstr "Instalador automático (recomendado)"

msgctxt "#30513"
msgid "View manual installation instructions"
msgstr "Ver instruções de instalação manual"

msgctxt "#30514"
msgid "loiolog is not installed.\n\nDownload and install automatically?"
msgstr "loiolog não está instalado.\n\nBaixar e instalar automaticamente?"

msgctxt "#30515"
msgid "loiolog instructions"
msgstr "Instruções loiolog"

msgctxt "#30516"
msgid "[B]How to install loiolog[/B]\n\n1. Settings - System - Addons - enable Unknown Sources\n\n2. Settings - File Manager - Add source:\n   {0}\n\n3. Addons - Install from zip file - loiolog\n   repository.loiolog-x.x.x.zip\n\n4. Install from repository - loiolog - Program Addons - loiolog"
msgstr "[B]Como instalar loiolog[/B]\n\n1. Configurações - Sistema - Addons - ativar Fontes desconhecidas\n\n2. Configurações - Gerenciador de arquivos - Adicionar fonte:\n   {0}\n\n3. Addons - Instalar de arquivo zip - loiolog\n   repository.loiolog-x.x.x.zip\n\n4. Instalar do repositório - loiolog - Addons de programa - loiolog"

msgctxt "#30517"
msgid "Add advanced editor to Kodi favourites"
msgstr "Adicionar editor avançado aos favoritos do Kodi"

msgctxt "#30518"
msgid "Advanced editor added. Reload skin or restart Kodi to see it"
msgstr "Editor adicionado. Recarregue a skin ou reinicie o Kodi"

msgctxt "#30519"
msgid "Advanced editor already in Kodi favourites"
msgstr "Editor avançado já existe nos favoritos do Kodi"

msgctxt "#30520"
msgid "Close"
msgstr "Fechar"

msgctxt "#30521"
msgid "Add the Advanced Editor to Kodi favourites?\n\nAllows opening it directly without launching the addon.\n\nIf cancelled, it can be added later from Settings. Kodi must be restarted for it to appear in the favourites list."
msgstr "Adicionar o Editor Avançado aos favoritos do Kodi?\n\nPermite abri-lo diretamente sem iniciar o addon.\n\nSe cancelado, pode ser adicionado depois nas Configurações. O Kodi deve ser reiniciado para que apareça na lista de favoritos."

msgctxt "#30522"
msgid "Flow FavManager"
msgstr "Flow FavManager"
